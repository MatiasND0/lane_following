<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>lane_detection</name>
  <version>0.1.0</version>
  <description>
    Pipeline de detección de carril para BFMC.
    Nodo C++ con pipeline completo + GUI Python para debug.
  </description>
  <maintainer email="you@example.com">BFMC Team</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>sensor_msgs</depend>
  <depend>std_msgs</depend>
  <depend>rcl_interfaces</depend>
  <depend>cv_bridge</depend>

  <exec_depend>python3-pyqt5</exec_depend>
  <exec_depend>rclpy</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>